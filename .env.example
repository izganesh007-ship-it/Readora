# ============================================
# READORA - Environment Configuration
# ============================================

# Flask Secret Key (generate a strong random string)
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-this-in-production

# Admin Credentials (CHANGE THESE IMMEDIATELY)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-admin-password

# Bitcoin Payment (Blockonomics API)
# Get API key from: https://www.blockonomics.co/
BLOCKONOMICS_API_KEY=your-blockonomics-api-key

# Database
# SQLite (default for simplicity) or PostgreSQL
DATABASE_URL=sqlite:///readora.db

# File Upload Settings
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=52428800

# Mail Settings (for order confirmations - optional)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# reCAPTCHA (optional but recommended for admin login)
RECAPTCHA_SITE_KEY=your-recaptcha-site-key
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key

# Rate Limiting (attempts before lockout)
MAX_LOGIN_ATTEMPTS=3
LOCKOUT_DURATION_MINUTES=30

# App Settings
APP_NAME=Readora
APP_URL=http://localhost:5000
